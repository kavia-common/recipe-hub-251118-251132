# Request the orchestrator to provide these values in recipe_backend/.env

DATABASE_URL=postgresql+psycopg://username:password@hostname:5432/recipehub
JWT_SECRET_KEY=replace-with-a-secure-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=120
CORS_ORIGINS=http://localhost:3000
DEFAULT_ADMIN_EMAIL=admin@recipehub.dev
DEFAULT_ADMIN_PASSWORD=ChangeMe123!
